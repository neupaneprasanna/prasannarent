modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3000

[userenv]

[userenv.shared]
PORT = "5000"
JWT_EXPIRES_IN = "7d"
NEXT_PUBLIC_API_URL = "/api"
NEXT_PUBLIC_WS_URL = "ws://localhost:5000"
NEXT_PUBLIC_SUPABASE_URL = "https://bjpvxrrxjibxzqzkokuh.supabase.co"
